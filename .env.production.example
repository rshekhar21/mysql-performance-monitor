NODE_ENV=production
LOG_LEVEL=info

# Public production origin used by API CORS and by the React build.
PUBLIC_APP_URL=https://mysqlmonitor.myebs.in
PUBLIC_API_BASE_URL=https://mysqlmonitor.myebs.in
CORS_ORIGIN=https://mysqlmonitor.myebs.in

# Host bindings for CloudPanel reverse proxy. Keep these on loopback.
WEB_HOST=127.0.0.1
WEB_HOST_PORT=8085
API_HOST=127.0.0.1
API_HOST_PORT=4400
COLLECTOR_HOST=127.0.0.1
COLLECTOR_HOST_PORT=4410

# Containerized application database. This database is private to Docker and is not published to the VPS.
APP_DB_NAME=mysql_monitor
APP_DB_USER=monitor_app
APP_DB_PASSWORD=replace-generated-by-install-production
APP_DB_ROOT_PASSWORD=replace-generated-by-install-production

# Runtime connection URL inside Docker. install-production.sh/deploy-production.sh override this for services.
APP_DATABASE_URL=mysql://monitor_app:replace-generated-by-install-production@app-db:3306/mysql_monitor

# Generated during first install. Must be at least 32 characters.
JWT_SECRET=replace-generated-by-install-production
CREDENTIAL_ENCRYPTION_KEY=replace-generated-by-install-production

AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

API_PORT=4000
COLLECTOR_HEALTH_PORT=4100
COLLECTOR_CONCURRENCY=5
COLLECT_STATUS_INTERVAL_MS=15000
COLLECT_INNODB_INTERVAL_MS=30000
COLLECT_STORAGE_INTERVAL_MS=300000
COLLECT_TABLE_SIZE_INTERVAL_MS=900000
COLLECT_QUERY_DIGEST_INTERVAL_MS=60000
COLLECT_REPLICATION_INTERVAL_MS=30000
RETENTION_HIGH_FREQUENCY_DAYS=30
RETENTION_STORAGE_DAYS=1095
RETENTION_COLLECTOR_RUN_DAYS=90

# Optional first admin seed. Set these before first install. Seed is idempotent and will not overwrite users.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace-with-a-long-random-password
