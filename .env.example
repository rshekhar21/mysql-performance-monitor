NODE_ENV=development
LOG_LEVEL=info

APP_DATABASE_URL=mysql://monitor_app:monitor_app_password@localhost:3306/mysql_monitor
CREDENTIAL_ENCRYPTION_KEY=replace-with-at-least-32-characters
JWT_SECRET=replace-with-at-least-32-characters
MONITORED_MYSQL_CONNECT_TIMEOUT_MS=15000

API_PORT=4000
CORS_ORIGIN=http://localhost:5173
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

COLLECTOR_HEALTH_PORT=4100
COLLECTOR_CONCURRENCY=5
COLLECT_STATUS_INTERVAL_MS=15000
COLLECT_INNODB_INTERVAL_MS=30000
COLLECT_STORAGE_INTERVAL_MS=300000
COLLECT_TABLE_SIZE_INTERVAL_MS=900000
COLLECT_QUERY_DIGEST_INTERVAL_MS=60000
COLLECT_REPLICATION_INTERVAL_MS=30000
RETENTION_HIGH_FREQUENCY_DAYS=30
RETENTION_STORAGE_DAYS=1095
RETENTION_COLLECTOR_RUN_DAYS=90

VITE_API_BASE_URL=http://localhost:4000

# Optional local seed user. Do not use these values in production.
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=change-this-local-password
